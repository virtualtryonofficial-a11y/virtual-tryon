generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String         @id @default(uuid())
  name          String
  shopifyDomain       String         @unique
  apiKey              String         @unique @default(uuid())
  encryptedShopifyToken String?
  features            String[]       // ["tryon", "size_intelligence"]
  createdAt           DateTime       @default(now())

  config        TenantConfig?
  products      Product[]
  tryonRequests TryonRequest[]
  leads         Lead[]
  customers     Customer[]
}

model TenantConfig {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  primaryColor   String   @default("#000000")
  complimentTone String   @default("friendly")  // friendly | luxury | playful
  logoUrl        String?
  segmindModel   String   @default("fashion-tryon-v1")
  buttonStyle       String   @default("rounded")  // rounded | square | capsule
  widgetTheme       String   @default("light")    // light | dark | glassmorphism
  watermarkKey      String?
  watermarkScale    Float    @default(0.21)
  watermarkPosition String   @default("bottom-right")
  watermarkOpacity  Float    @default(0.85)
  watermarkType     String   @default("corner-logo") // corner-logo | pattern-text | pattern-logo | hybrid
  watermarkText     String?
  watermarkRotation Float    @default(-30)
  watermarkSpacing  Int      @default(345)
  leadCaptureEnabled Boolean @default(false)
  leadCaptureConfig  Json?
  updatedAt         DateTime @updatedAt
}

model Product {
  id                    String         @id @default(uuid())
  tenantId              String
  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopifyProductId      String
  imageUrl              String
  category              String?
  createdAt             DateTime       @default(now())
  preferredGarmentImage String?
  images                Json?          // Array of product images with url, position, altText, filename, metadata

  tryonRequests    TryonRequest[]

  @@unique([tenantId, shopifyProductId])
}

model TryonRequest {
  id                String    @id @default(uuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  status            String    @default("queued")  // queued | processing | completed | failed
  userImageKey      String?   // R2 key — deleted after 24h by cleanup processor
  generatedImageKey String?   // R2 key — deleted after 7 days by cleanup processor
  previewImageKey   String?   // R2 key — deleted after 7 days by cleanup processor
  compliment        String?
  styleScore        Float?
  errorMessage      String?
  processingTimeMs  Int?
  complimentCached  Boolean   @default(false)  // true = served from Redis, no Gemini call made
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lead              Lead?
}

model Lead {
  id                 String       @id @default(uuid())
  tenantId           String
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tryonRequestId     String       @unique
  tryonRequest       TryonRequest @relation(fields: [tryonRequestId], references: [id], onDelete: Cascade)
  customerId         String?
  customer           Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName       String
  phoneNumber        String
  countryCode        String
  marketingConsentAt DateTime?
  whatsappOptInAt    DateTime?
  status             String       @default("NEW") // NEW | MARKETING_READY | MESSAGE_SENT | DELIVERED | CLICKED | PURCHASED | UNSUBSCRIBED
  campaignCount      Int          @default(0)
  lastCampaignAt     DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  metadata           Json?

  @@unique([tenantId, tryonRequestId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, countryCode, phoneNumber])
}


model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  action    String
  actor     String?  // 'admin' | 'system' | tenantId
  ipAddress String?
  metadata  Json
  createdAt DateTime @default(now())
}

model OtpSession {
  id                   String    @id @default(uuid())
  tenantId             String
  tryonRequestId       String    @unique
  customerName         String
  countryCode          String
  phoneNumber          String
  hashedOtp            String
  expiresAt            DateTime
  resendCount          Int       @default(0)
  verificationAttempts Int       @default(0)
  status               String    @default("PENDING") // PENDING | SENT | VERIFIED | EXPIRED | FAILED | LOCKED
  lastSentAt           DateTime?
  verifiedAt           DateTime?
  provider             String?
  providerMessageId    String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  metadata             Json?
  marketingConsent     Boolean   @default(false)

  @@index([tenantId, id])
  @@index([tenantId, tryonRequestId])
  @@index([tenantId, countryCode, phoneNumber])
}

model Customer {
  id                   String   @id @default(uuid())
  tenantId             String
  phone                String
  countryCode          String
  preferredLanguage    String?  // e.g. 'en', 'ta'
  
  createdAt            DateTime @default(now())
  lastSeenAt           DateTime @default(now())
  lastDeviceName       String?  // Rolled up from active sessions
  
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions             CustomerSession[]
  leads                Lead[]
  
  @@unique([tenantId, countryCode, phone])
}

model CustomerSession {
  id               String    @id @default(uuid())
  customerId       String
  sessionTokenHash String    @unique
  sessionVersion   Int       @default(1) // For sweeping invalidations/rotation
  
  deviceName       String?
  lastIp           String?
  lastUserAgent    String?
  isActive         Boolean   @default(true)
  
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  revokedAt        DateTime?
  expiresAt        DateTime?
  
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
}
