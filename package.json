{
  "name": "virtual-trail",
  "private": true,
  "description": "AI Virtual Try-On SaaS Platform",
  "scripts": {
    "postinstall": "pnpm db:generate",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:worker\"",
    "dev:api": "pnpm --filter @trail/api dev",
    "dev:worker": "pnpm --filter @trail/worker dev",
    "start": "node --import tsx --max-old-space-size=280 monolith.ts",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:generate": "prisma generate --schema libs/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema libs/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema libs/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "concurrently": "^8.2.2",
    "prisma": "^5.22.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
