{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@trail/config": ["libs/config/src/index"],
      "@trail/db": ["libs/db/src/index"],
      "@trail/queue": ["libs/queue/src/index"],
      "@trail/ai": ["libs/ai/src/index"],
      "@trail/storage": ["libs/storage/src/index"],
      "@trail/tenant": ["libs/tenant/src/index"],
      "@trail/security": ["libs/security/src/index"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
